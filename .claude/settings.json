{
  "permissions": {
    "allow": [
      "Bash(wsl -e bash -c \"cat ~/.bashrc | grep -i nvm\")"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-commit-msg.sh"
          }
        ]
      }
    ]
  }
}
